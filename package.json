{
    "name": "typeorm-extension",
    "version": "3.9.0",
    "type": "module",
    "description": "A library to create/drop database, simple seeding data sets, ...",
    "author": {
        "name": "Peter Placzek",
        "email": "contact@tada5hi.net",
        "url": "https://github.com/tada5hi"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/tada5hi/typeorm-extension.git"
    },
    "main": "dist/index.mjs",
    "types": "dist/index.d.mts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        },
        "./bin/*": "./bin/*"
    },
    "files": [
        "bin",
        "dist"
    ],
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "build": "npm run build:types && npm run build:js",
        "build:types": "tsc --noEmit",
        "build:js": "tsdown",
        "test": "vitest --config test/vitest.config.ts --run",
        "test:coverage": "vitest --config test/vitest.config.ts --run --coverage",
        "lint": "eslint",
        "lint:fix": "npm run lint -- --fix",
        "docs:dev": "vitepress dev docs --temp .temp",
        "docs:build": "vitepress build docs --temp .temp",
        "docs:help": "vitepress --help",
        "prepare": "husky"
    },
    "keywords": [
        "database",
        "create",
        "drop",
        "api",
        "json-api",
        "jsonapi",
        "migration",
        "seeder",
        "seeding",
        "cli"
    ],
    "bin": {
        "typeorm-extension": "bin/cli.mjs"
    },
    "publishConfig": {
        "access": "public"
    },
    "license": "MIT",
    "dependencies": {
        "citty": "^0.2.2",
        "envix": "^1.5.0",
        "locter": "^2.2.1",
        "pascal-case": "^3.1.2",
        "rapiq": "^0.9.0",
        "reflect-metadata": "^0.2.2",
        "smob": "^1.5.0"
    },
    "peerDependencies": {
        "@faker-js/faker": ">=8.4.1",
        "typeorm": "^1.0.0"
    },
    "devDependencies": {
        "@faker-js/faker": "^9.9.0",
        "@swc/core": "^1.15.33",
        "@tada5hi/commitlint-config": "^1.3.1",
        "@tada5hi/eslint-config": "^2.3.0",
        "@tada5hi/tsconfig": "^0.7.2",
        "@types/node": "^25.9.1",
        "@vitest/coverage-v8": "^4.1.5",
        "better-sqlite3": "^12.4.6",
        "eslint": "^10.3.0",
        "eslint-plugin-vue": "^10.9.1",
        "husky": "^9.1.7",
        "tsdown": "^0.21.10",
        "typeorm": "^1.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2",
        "unplugin-swc": "^1.5.9",
        "vitepress": "^1.6.4",
        "vitest": "^4.1.5",
        "vue": "^3.5.25"
    }
}
